{
  "name": "tsdk-server-adapters",
  "version": "1.0.0-alpha.1",
  "main": "lib/index.js",
  "module": "esm/index.js",
  "repository": "tsdk-monorepo/tsdk",
  "bugs": "https://github.com/tsdk-monorepo/tsdk/issues",
  "homepage": "https://tsdk.dev",
  "scripts": {
    "build": "concurrently \"npm run build:cjs\"  \"npm run build:esm\"",
    "build:cjs": "rm -rf lib && tsc --project tsconfig.json && rm -rf lib/tests",
    "build:esm": "rm -rf esm && tsc --project tsconfig.esm.json && rm -rf esm/tests",
    "lint": "eslint ./src --ext .ts,.tsx --fix",
    "checktype": "tsc --noEmit",
    "test": "vitest --run --testTimeout=120000 --hookTimeout=60000",
    "start-publish": "npm run build && node ../../scripts/purge-pkg-for-publish.mjs && npm publish --tag alpha --access public --no-git-checks --provenance --registry=https://registry.npmjs.org"
  },
  "files": [
    "lib/*",
    "esm/*",
    "README.md"
  ],
  "keywords": [
    "tsdk",
    "http",
    "express",
    "socket.io",
    "fastify",
    "backend",
    "typesafe API"
  ],
  "dependencies": {
    "eventemitter3": "^5.0.1",
    "@standard-schema/spec": "^1.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "typescript": "^5.9.2",
    "@tsconfig/recommended": "^1.0.10",
    "vitest": "^3.2.4",
    "concurrently": "^9.1.2",
    "zod": "^4",
    "valibot": "^1.1.0",
    "arktype": "^2.1.20",
    "hono": "^4.8.2",
    "fastify": "^5.4.0",
    "@fastify/express": "^4.0.2",
    "@hono/node-server": "^1.14.4",
    "express": "^5.1.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "multer": "^2.0.2",
    "@types/multer": "^2.0.0"
  },
  "peerDependencies": {
    "express": "^5.1.0",
    "zod": "^4",
    "socket.io": "^4.8.1",
    "hono": "^4.8.2",
    "fastify": "^5.4.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "socket.io": {
      "optional": true
    },
    "hono": {
      "optional": true
    },
    "fastify": {
      "optional": true
    }
  },
  "license": "MIT"
}
