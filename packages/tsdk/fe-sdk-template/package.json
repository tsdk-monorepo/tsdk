{
  "name": "fe-sdk-template",
  "version": "1.0.0",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "require": "./lib/index.js",
  "scripts": {
    "tsc:build": "concurrently \"npm run tsc:build:cjs\"  \"npm run tsc:build:esm\"",
    "tsc:build:cjs": "tsc --project tsconfig.json",
    "tsc:build:esm": "tsc --project tsconfig.esm.json",
    "doc:build": "typedoc --customJs popover.js src/**.ts",
    "serve": "serve docs"
  },
  "dependencies": {
    "axios": "^1.8.4",
    "xior": "^0.7.8"
  },
  "devDependencies": {
    "typescript": "^5.9.2",
    "typedoc": "^0.28.14",
    "concurrently": "^9.2.0",
    "@standard-schema/spec": "^1.0.0"
  },
  "peerDependencies": {
    "socket.io-client": "^4.8.1"
  },
  "peerDependenciesMeta": {
    "socket.io-client": {
      "optional": true
    }
  },
  "files": [
    "lib",
    "esm",
    "src"
  ]
}
