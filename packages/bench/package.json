{
  "private": true,
  "name": "tsdk-bench",
  "description": "Benchmark for tsdk",
  "version": "1.0.0",
  "scripts": {
    "build": "node ./node_modules/tsdk/bin/tsdk.js --nest build all",
    "dev": "pnpm start express",
    "start": "cross-env NODE_ENV=production nest start --watch",
    "start:all": "concurrently \"pnpm start express\" \"pnpm start tsdk-express\" \"pnpm start hono\" \"pnpm start tsdk-hono\" \"pnpm start trpc-express\" \"pnpm start fastify\"",
    "bench": "sh bench.sh",
    "bench-opi5": "sh bench-opi5.sh",
    "test": "vitest --run",
    "lint": "eslint . --ext .ts,.tsx --fix ./src",
    "checktype": "tsc --noEmit"
  },
  "dependencies": {
    "tsdk-server-adapters": "^0.3.0",
    "express": "^5.1.0",
    "zod": "^3.25.48",
    "hono": "^4.7.6",
    "@hono/node-server": "^1.14.1",
    "@trpc/server": "^10.45.2",
    "fastify": "^5.3.0",
    "@standard-schema/spec": "^1.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.6",
    "@types/express": "^5.0.1",
    "tsdk": "workspace:*",
    "concurrently": "^9.1.2",
    "vitest": "^3.0.7",
    "webpack": "^5.99.5",
    "webpack-node-externals": "^3.0.0",
    "typescript": "^5.8.2"
  },
  "license": "MIT"
}
